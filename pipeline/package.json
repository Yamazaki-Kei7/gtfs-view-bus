{
	"name": "pipeline",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --test-scheduled --persist-to ../.wrangler/state",
		"deploy": "wrangler deploy",
		"test": "vitest run",
		"check": "tsc --noEmit",
		"update:odpt-manifest": "node --import tsx scripts/update-odpt-manifest.ts",
		"cf:check": "WRANGLER_LOG_PATH=../.tmp/wrangler-logs wrangler deploy --dry-run",
		"cf:types": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/containers": "^0.3.7",
		"gtfs-core": "workspace:*",
		"tsx": "^4.22.4"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260628.1",
		"@types/node": "^26.1.0",
		"cheerio": "^1.2.0",
		"fflate": "^0.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"wrangler": "^4.106.0"
	}
}
